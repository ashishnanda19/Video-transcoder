# ─── Database ────────────────────────────────────────────────
REDIS_URL=
MONGO_URI=

# ─── Server ──────────────────────────────────────────────────
PORT=8000

# ─── AWS Credentials (IAM User) ──────────────────────────────
MY_AWS_ACCESS_KEY_ID=
MY_AWS_SECRET_ACCESS_KEY=

# ─── S3 Buckets ──────────────────────────────────────────────
TEMP_S3_BUCKET_NAME=
FINAL_S3_BUCKET_NAME=

# ─── ECS Configuration ───────────────────────────────────────
# ECS Cluster name (e.g. video-transcoder-cluster)
CLUSTER=
# ECS Task Definition ARN or name:revision (e.g. video-transcoder-task:1)
TASK=
# Comma-separated subnet IDs from your VPC (e.g. subnet-abc123,subnet-def456)
ECS_SUBNETS=
# Security Group ID that allows outbound traffic for ECS tasks
ECS_SECURITY_GROUP=

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Format: <your-render-backend-url>/api/v1/user/login
GOOGLE_CALLBACK_URL=

# ─── App URLs ────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=
# A long random string for session signing
SESSION_SECRET=

# ─── Webhook ─────────────────────────────────────────────────
# Format: <your-render-backend-url>/api/v1/video/ecs-trigger
WEBHOOK_URL=
